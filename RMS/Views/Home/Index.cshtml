@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-3">Dashboard</h2>

<div class="row g-3">
    <div class="col-md-3"><div class="card"><div class="card-body"><h6>Total Customers</h6><h3>@ViewBag.TotalCustomers</h3></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><h6>Total Movies</h6><h3>@ViewBag.TotalMovies</h3></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><h6>Total Theatres</h6><h3>@ViewBag.TotalTheatres</h3></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><h6>Total Halls</h6><h3>@ViewBag.TotalHalls</h3></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><h6>Total Shows</h6><h3>@ViewBag.TotalShows</h3></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><h6>Total Tickets</h6><h3>@ViewBag.TotalTickets</h3></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><h6>Total Payments</h6><h3>@ViewBag.TotalPayments</h3></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><h6>Paid Payments</h6><h3>@ViewBag.PaidPayments</h3></div></div></div>
</div>