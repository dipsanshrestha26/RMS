@model System.Data.DataTable
@{
    ViewData["Title"] = "Movies";
}

<h2>Movie Details</h2>

<div class="card mb-3">
    <div class="card-body">
        <form method="post" asp-action="Create" class="row g-2">
            <div class="col-md-2"><input class="form-control" name="movieId" placeholder="Movie ID" required /></div>
            <div class="col-md-3"><input class="form-control" name="movieTitle" placeholder="Movie Title" required /></div>
            <div class="col-md-2"><input class="form-control" name="movieGenre" placeholder="Genre" required /></div>
            <div class="col-md-2"><input class="form-control" name="movieLanguage" placeholder="Language" required /></div>
            <div class="col-md-2"><input class="form-control" name="movieDuration" placeholder="Duration" required /></div>
            <div class="col-md-2"><input type="date" class="form-control" name="releaseDate" required /></div>
            <div class="col-12"><button class="btn btn-success" type="submit">Add Movie</button></div>
        </form>
    </div>
</div>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Title</th>
            <th>Genre</th>
            <th>Language</th>
            <th>Duration</th>
            <th>Release Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (System.Data.DataRow row in Model.Rows)
        {
            <tr>
                <td>@row["MOVIE_ID"]</td>
                <td>@row["MOVIE_TITLE"]</td>
                <td>@row["MOVIE_GENRE"]</td>
                <td>@row["MOVIE_LANGUAGE"]</td>
                <td>@row["MOVIE_DURATION"]</td>
                <td>@row["RELEASE_DATE"]</td>
                <td>
                    <form method="post" asp-action="Delete" style="display:inline;">
                        <input type="hidden" name="movieId" value="@row["MOVIE_ID"]" />
                        <button class="btn btn-danger btn-sm">Delete</button>
                    </form>

                    <form method="post" asp-action="Update" class="mt-2">
                        <input type="hidden" name="movieId" value="@row["MOVIE_ID"]" />
                        <input name="movieTitle" value="@row["MOVIE_TITLE"]" class="form-control form-control-sm mb-1" />
                        <input name="movieGenre" value="@row["MOVIE_GENRE"]" class="form-control form-control-sm mb-1" />
                        <input name="movieLanguage" value="@row["MOVIE_LANGUAGE"]" class="form-control form-control-sm mb-1" />
                        <input name="movieDuration" value="@row["MOVIE_DURATION"]" class="form-control form-control-sm mb-1" />
                        <input type="date" name="releaseDate" class="form-control form-control-sm mb-1" />
                        <button class="btn btn-primary btn-sm">Save</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>