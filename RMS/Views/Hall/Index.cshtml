@model System.Data.DataTable
@{
    ViewData["Title"] = "Hall Management";
    var theatres = ViewBag.Theatres as System.Data.DataTable;
}

<style>
    :root {
        --bg: #f6f8fb;
        --surface: #fff;
        --border: #e5e7eb;
        --border-dark: #d1d5db;
        --text: #111827;
        --text-soft: #6b7280;
        --secondary: #475569;
        --hover: #f9fafb;
        --edit-bg: #f8fafc;
        --success: #f0fdf4;
        --danger: #fef2f2;
        --shadow: 0 10px 30px rgba(15,23,42,0.06);
        --radius: 18px;
    }

    body {
        background: var(--bg);
    }

    .page-shell {
        padding: 8px 0 20px;
    }

    .page-header, .panel, .table-panel {
        background: var(--surface);
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
    }

    .page-header {
        border-radius: 24px;
        padding: 28px 30px;
        margin-bottom: 26px;
    }

        .page-header h2 {
            margin: 0;
            font-size: 29px;
            font-weight: 700;
            color: var(--text);
        }

    .panel {
        border-radius: var(--radius);
        margin-bottom: 24px;
    }

    .panel-body {
        padding: 24px;
    }

    .panel-title {
        margin: 0 0 18px;
        color: var(--text);
        font-size: 20px;
        font-weight: 650;
    }

    .form-label {
        font-weight: 600;
        color: var(--secondary);
        margin-bottom: 7px;
        font-size: 14px;
    }

    .form-control, .form-select {
        border-radius: 12px;
        border: 1px solid var(--border-dark);
        min-height: 44px;
        padding: 10px 14px;
    }

        .form-control:focus, .form-select:focus {
            border-color: #94a3b8;
            box-shadow: 0 0 0 .2rem rgba(148,163,184,.15);
        }

    .btn {
        border-radius: 12px;
        font-weight: 600;
        padding: 10px 16px;
    }

    .btn-add, .btn-save {
        background: #1f2937;
        color: #fff;
    }

        .btn-add:hover, .btn-save:hover {
            background: #111827;
            color: #fff;
        }

    .btn-edit {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
    }

        .btn-edit:hover {
            background: #dbeafe;
            color: #1e40af;
            border-color: #93c5fd;
        }

    .btn-cancel {
        background: #fff;
        color: #334155;
        border: 1px solid #cbd5e1;
    }

        .btn-cancel:hover {
            background: #f8fafc;
            color: #111827;
        }

    .btn-delete {
        background: #fff;
        color: #7f1d1d;
        border: 1px solid #fecaca;
    }

        .btn-delete:hover {
            background: #fef2f2;
            color: #7f1d1d;
            border-color: #fca5a5;
        }

    .utility-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        margin-bottom: 14px;
    }

        .utility-bar h4 {
            margin: 0;
            font-size: 20px;
            font-weight: 650;
            color: var(--text);
        }

    .search-box {
        max-width: 320px;
    }

    .table-panel {
        border-radius: var(--radius);
        overflow: hidden;
    }

    .table {
        margin-bottom: 0;
    }

        .table thead th {
            background: #1f2937;
            color: #ffffff;
            font-weight: 700;
            font-size: 14px;
            padding: 14px 16px;
            border: none;
            text-transform: none;
            letter-spacing: 0;
            vertical-align: middle;
        }

        .table tbody td {
            padding: 14px 16px;
            vertical-align: middle;
            border-color: #eef2f7;
            color: #111827;
        }

        .table tbody tr:hover {
            background: #f9fafb;
        }

    .action-group {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .edit-row {
        background: var(--edit-bg) !important;
    }

    .alert {
        border-radius: 14px;
        box-shadow: var(--shadow);
    }

    .alert-success {
        background: var(--success);
        border: 1px solid #bbf7d0;
        color: #166534;
    }

    .alert-danger {
        background: var(--danger);
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    .empty-row {
        text-align: center;
        color: var(--text-soft);
        padding: 24px !important;
    }
</style>

<div class="page-shell">
    <div class="page-header">
        <h2>Hall Management</h2>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="panel">
        <div class="panel-body">
            <h4 class="panel-title">Add New Hall</h4>

            <form method="post" asp-action="Create" class="row g-3">
                @Html.AntiForgeryToken()

                <div class="col-md-2">
                    <label class="form-label">Hall ID</label>
                    <input type="text" name="hallId" class="form-control" required />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Theatre</label>
                    <select class="form-select" name="theatreId" required>
                        <option value="">Select Theatre</option>
                        @foreach (System.Data.DataRow t in theatres.Rows)
                        {
                            <option value="@t["THEATRE_ID"]">@t["THEATRE_ID"] - @t["THEATRE_NAME"]</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Hall</label>
                    <input type="text" name="hallName" class="form-control" required />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Capacity</label>
                    <input type="number" name="seatingCapacity" class="form-control" required />
                </div>

                <div class="col-12">
                    <button type="submit" class="btn btn-add">Add Hall</button>
                </div>
            </form>
        </div>
    </div>

    <div class="utility-bar">
        <h4>Hall Records</h4>
        <input type="text" id="hallSearch" class="form-control search-box" placeholder="Search hall..." />
    </div>

    <div class="table-panel">
        <table class="table align-middle" id="hallTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Theatre</th>
                    <th>Hall</th>
                    <th>Capacity</th>
                    <th style="width:250px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Rows.Count > 0)
                {
                    @foreach (System.Data.DataRow row in Model.Rows)
                    {
                        var id = row["HALL_ID"].ToString();
                        var theatreId = row["THEATRE_ID"].ToString();
                        var theatreName = row["THEATRE_NAME"].ToString();
                        var hallName = row["HALL_NAME"].ToString();
                        var capacity = row["SEATING_CAPACITY"].ToString();

                        <tr id="viewRow_@id">
                            <td>@id</td>
                            <td>@theatreName</td>
                            <td>@hallName</td>
                            <td>@capacity</td>
                            <td>
                                <div class="action-group">
                                    <button type="button" class="btn btn-edit btn-sm" onclick="enableEdit('@id')">Edit</button>

                                    <form method="post" asp-action="Delete" style="display:inline;" onsubmit="return confirm('Delete this hall?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="hallId" value="@id" />
                                        <button type="submit" class="btn btn-delete btn-sm">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>

                        <tr id="editRow_@id" class="edit-row" style="display:none;">
                            <td colspan="5">
                                <form method="post" asp-action="Update" class="row g-3 align-items-end">
                                    @Html.AntiForgeryToken()

                                    <div class="col-md-2">
                                        <label class="form-label">ID</label>
                                        <input type="text" name="hallId" value="@id" class="form-control" readonly />
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label">Theatre</label>
                                        <select class="form-select" name="theatreId" required>
                                            @foreach (System.Data.DataRow t in theatres.Rows)
                                            {
                                                if (t["THEATRE_ID"].ToString() == theatreId)
                                                {
                                                    <option value="@t["THEATRE_ID"]" selected>@t["THEATRE_ID"] - @t["THEATRE_NAME"]</option>
                                                }
                                                else
                                                {
                                                    <option value="@t["THEATRE_ID"]">@t["THEATRE_ID"] - @t["THEATRE_NAME"]</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                    <div class="col-md-3">
                                        <label class="form-label">Hall</label>
                                        <input type="text" name="hallName" value="@hallName" class="form-control" required />
                                    </div>

                                    <div class="col-md-2">
                                        <label class="form-label">Capacity</label>
                                        <input type="number" name="seatingCapacity" value="@capacity" class="form-control" required />
                                    </div>

                                    <div class="col-md-1">
                                        <div class="action-group mt-2">
                                            <button type="submit" class="btn btn-save btn-sm">Save</button>
                                            <button type="button" class="btn btn-cancel btn-sm" onclick="cancelEdit('@id')">Cancel</button>
                                        </div>
                                    </div>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="empty-row">No hall records found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function enableEdit(id) {
        document.getElementById("viewRow_" + id).style.display = "none";
        document.getElementById("editRow_" + id).style.display = "";
    }

    function cancelEdit(id) {
        document.getElementById("editRow_" + id).style.display = "none";
        document.getElementById("viewRow_" + id).style.display = "";
    }

    document.getElementById("hallSearch").addEventListener("keyup", function () {
        let filter = this.value.toLowerCase();
        let rows = document.querySelectorAll("#hallTable tbody tr");

        rows.forEach(row => {
            let text = row.innerText.toLowerCase();
            row.style.display = text.includes(filter) ? "" : "none";
        });
    });
</script>