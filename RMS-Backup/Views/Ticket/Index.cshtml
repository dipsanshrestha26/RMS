@model System.Data.DataTable
@using System
@{
    ViewData["Title"] = "Ticket Management";
    var customers = ViewBag.Customers as System.Data.DataTable;
    var shows = ViewBag.Shows as System.Data.DataTable;
    var seats = ViewBag.Seats as List<string>;
    string selectedShowId = ViewBag.SelectedShowId as string ?? "";
}

<style>
    :root {
        --bg: #f6f8fb;
        --surface: #fff;
        --border: #e5e7eb;
        --border-dark: #d1d5db;
        --text: #111827;
        --text-soft: #6b7280;
        --secondary: #475569;
        --hover: #f9fafb;
        --success: #f0fdf4;
        --danger: #fef2f2;
        --info: #eff6ff;
        --shadow: 0 10px 30px rgba(15,23,42,0.06);
        --radius: 18px;
    }

    body {
        background: var(--bg);
    }

    .page-shell {
        padding: 8px 0 20px;
    }

    .page-header, .panel, .table-panel {
        background: var(--surface);
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
    }

    .page-header {
        border-radius: 24px;
        padding: 28px 30px;
        margin-bottom: 26px;
    }

        .page-header h2 {
            margin: 0;
            font-size: 29px;
            font-weight: 700;
            color: var(--text);
        }

        .page-header p {
            margin: 8px 0 0;
            color: var(--text-soft);
            line-height: 1.7;
            font-size: 15px;
        }

    .panel {
        border-radius: var(--radius);
        margin-bottom: 24px;
    }

    .panel-body {
        padding: 24px;
    }

    .panel-title {
        margin: 0 0 18px;
        color: var(--text);
        font-size: 20px;
        font-weight: 650;
    }

    .form-label {
        font-weight: 600;
        color: var(--secondary);
        margin-bottom: 7px;
        font-size: 14px;
    }

    .form-control, .form-select {
        border-radius: 12px;
        border: 1px solid var(--border-dark);
        min-height: 44px;
        padding: 10px 14px;
    }

        .form-control:focus, .form-select:focus {
            border-color: #94a3b8;
            box-shadow: 0 0 0 .2rem rgba(148,163,184,.15);
        }

    .btn {
        border-radius: 12px;
        font-weight: 600;
        padding: 10px 16px;
    }

    .btn-add {
        background: #1f2937;
        color: #fff;
    }

        .btn-add:hover {
            background: #111827;
            color: #fff;
        }

    .btn-delete {
        background: #fff;
        color: #7f1d1d;
        border: 1px solid #fecaca;
    }

        .btn-delete:hover {
            background: #fef2f2;
            color: #7f1d1d;
        }

    .alert {
        border-radius: 14px;
        box-shadow: var(--shadow);
    }

    .alert-success {
        background: var(--success);
        border: 1px solid #bbf7d0;
        color: #166534;
    }

    .alert-danger {
        background: var(--danger);
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    .seat-box {
        background: var(--info);
        border: 1px solid #bfdbfe;
        color: #1e3a8a;
        border-radius: 14px;
        padding: 14px 16px;
        margin-bottom: 20px;
    }

    .table-panel {
        border-radius: var(--radius);
        overflow-x: auto;
    }

    .table {
        margin-bottom: 0;
        min-width: 1200px;
    }

        .table thead th {
            background: #1f2937;
            color: #ffffff;
            font-weight: 700;
            font-size: 14px;
            padding: 14px 16px;
            border: none;
            white-space: nowrap;
        }

        .table tbody td {
            padding: 14px 16px;
            vertical-align: middle;
            border-color: #eef2f7;
            color: #111827;
        }

        .table tbody tr:hover {
            background: #f9fafb;
        }

    .empty-row {
        text-align: center;
        color: var(--text-soft);
        padding: 24px !important;
    }
</style>

<div class="page-shell">
    <div class="page-header">
        <h2>Ticket Management</h2>
        <p>
            Create tickets against a specific show. The show dropdown clearly displays movie,
            theatre, hall, date, and time to avoid user confusion.
        </p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="panel">
        <div class="panel-body">
            <h4 class="panel-title">Add New Ticket</h4>

            <form method="post" asp-action="Create" class="row g-3">
                @Html.AntiForgeryToken()

                <div class="col-md-2">
                    <label class="form-label">Ticket ID</label>
                    <input class="form-control" name="ticketId" required />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Show</label>
                    <select class="form-select" name="showId" onchange="window.location='@Url.Action("Index", "Ticket")?showId=' + this.value" required>
                        <option value="">Select Show</option>
                        @foreach (System.Data.DataRow s in shows.Rows)
                        {
                            string sid = s["SHOW_ID"].ToString()!;
                            string movieTitle = s["MOVIE_TITLE"].ToString()!;
                            string hallName = s["HALL_NAME"].ToString()!;
                            string theatreName = s["THEATRE_NAME"].ToString()!;
                            string showDateText = Convert.ToDateTime(s["SHOW_DATE"]).ToString("dd/MM/yyyy");
                            string showTimeText = s["SHOW_TIME"].ToString()!;

                            string label = $"{sid} - {movieTitle} | {theatreName} | {hallName} | {showDateText} {showTimeText}";

                            if (sid == selectedShowId)
                            {
                                <option value="@sid" selected>@label</option>
                            }
                            else
                            {
                                <option value="@sid">@label</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Customer</label>
                    <select class="form-select" name="customerId" required>
                        <option value="">Select Customer</option>
                        @foreach (System.Data.DataRow c in customers.Rows)
                        {
                            <option value="@c["CUSTOMER_ID"]">@c["CUSTOMER_ID"] - @c["CUSTOMER_NAME"]</option>
                        }
                    </select>
                </div>

                <div class="col-md-1">
                    <label class="form-label">Seat</label>
                    <select class="form-select" name="seatNumber" required>
                        <option value="">Seat</option>
                        @if (seats != null)
                        {
                            foreach (var seat in seats)
                            {
                                <option value="@seat">@seat</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Booking Date/Time</label>
                    <input type="datetime-local"
                           class="form-control"
                           name="bookingDatetime"
                           value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")"
                           required />
                </div>

                <div class="col-md-2">
                    <label class="form-label">Ticket Status</label>
                    <select class="form-select" name="ticketStatus" required>
                        <option value="">Select Status</option>
                        <option value="Pending">Pending</option>
                        <option value="Booked">Booked</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>

                <div class="col-12">
                    <button class="btn btn-add" type="submit">Add Ticket</button>
                </div>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(selectedShowId) && seats != null)
    {
        <div class="seat-box">
            <strong>Available Seats for Show @selectedShowId:</strong>
            @if (seats.Count > 0)
            {
                @string.Join(", ", seats)
            }
            else
            {
                <span>No seats available.</span>
            }
        </div>
    }

    <div class="table-panel">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Show</th>
                    <th>Movie</th>
                    <th>Theatre</th>
                    <th>Hall</th>
                    <th>Customer</th>
                    <th>Seat</th>
                    <th>Booking Date/Time</th>
                    <th>Status</th>
                    <th style="width:120px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Rows.Count > 0)
                {
                    @foreach (System.Data.DataRow row in Model.Rows)
                    {
                        DateTime bookingDt = Convert.ToDateTime(row["BOOKING_DATETIME"]);
                        <tr>
                            <td>@row["TICKET_ID"]</td>
                            <td>@row["SHOW_ID"]</td>
                            <td>@row["MOVIE_TITLE"]</td>
                            <td>@row["THEATRE_NAME"]</td>
                            <td>@row["HALL_NAME"]</td>
                            <td>@row["CUSTOMER_NAME"]</td>
                            <td>@row["SEAT_NUMBER"]</td>
                            <td>@bookingDt.ToString("dd/MM/yyyy hh:mm tt")</td>
                            <td>@row["TICKET_STATUS"]</td>
                            <td>
                                <form method="post" asp-action="Delete" onsubmit="return confirm('Delete this ticket?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ticketId" value="@row["TICKET_ID"]" />
                                    <button class="btn btn-delete btn-sm" type="submit">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="10" class="empty-row">No ticket records found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>