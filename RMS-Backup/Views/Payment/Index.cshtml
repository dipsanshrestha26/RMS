@model System.Data.DataTable
@using System
@{
    ViewData["Title"] = "Payment Management";
    var tickets = ViewBag.Tickets as System.Data.DataTable;
}

<style>
    :root {
        --bg: #f6f8fb;
        --surface: #fff;
        --border: #e5e7eb;
        --border-dark: #d1d5db;
        --text: #111827;
        --text-soft: #6b7280;
        --secondary: #475569;
        --hover: #f9fafb;
        --edit-bg: #f8fafc;
        --success: #f0fdf4;
        --danger: #fef2f2;
        --shadow: 0 10px 30px rgba(15,23,42,0.06);
        --radius: 18px;
    }

    body {
        background: var(--bg);
    }

    .page-shell {
        padding: 8px 0 20px;
    }

    .page-header, .panel, .table-panel {
        background: var(--surface);
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
    }

    .page-header {
        border-radius: 24px;
        padding: 28px 30px;
        margin-bottom: 26px;
    }

        .page-header h2 {
            margin: 0;
            font-size: 29px;
            font-weight: 700;
            color: var(--text);
        }

        .page-header p {
            margin: 8px 0 0;
            color: var(--text-soft);
            line-height: 1.7;
            font-size: 15px;
        }

    .panel {
        border-radius: var(--radius);
        margin-bottom: 24px;
    }

    .panel-body {
        padding: 24px;
    }

    .panel-title {
        margin: 0 0 18px;
        color: var(--text);
        font-size: 20px;
        font-weight: 650;
    }

    .form-label {
        font-weight: 600;
        color: var(--secondary);
        margin-bottom: 7px;
        font-size: 14px;
    }

    .form-control, .form-select {
        border-radius: 12px;
        border: 1px solid var(--border-dark);
        min-height: 44px;
        padding: 10px 14px;
    }

        .form-control:focus, .form-select:focus {
            border-color: #94a3b8;
            box-shadow: 0 0 0 .2rem rgba(148,163,184,.15);
        }

    .btn {
        border-radius: 12px;
        font-weight: 600;
        padding: 10px 16px;
    }

    .btn-add, .btn-save {
        background: #1f2937;
        color: #fff;
    }

        .btn-add:hover, .btn-save:hover {
            background: #111827;
            color: #fff;
        }

    .btn-edit, .btn-cancel {
        background: #fff;
        color: #334155;
        border: 1px solid #cbd5e1;
    }

        .btn-edit:hover, .btn-cancel:hover {
            background: #f8fafc;
            color: #111827;
        }

    .btn-delete {
        background: #fff;
        color: #7f1d1d;
        border: 1px solid #fecaca;
    }

        .btn-delete:hover {
            background: #fef2f2;
            color: #7f1d1d;
        }

    .utility-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        margin-bottom: 14px;
    }

        .utility-bar h4 {
            margin: 0;
            font-size: 20px;
            font-weight: 650;
            color: var(--text);
        }

    .search-box {
        max-width: 320px;
    }

    .table-panel {
        border-radius: var(--radius);
        overflow-x: auto;
    }

    .table {
        margin-bottom: 0;
        min-width: 980px;
    }

        .table thead th {
            background: #1f2937;
            color: #ffffff;
            font-weight: 700;
            font-size: 14px;
            padding: 14px 16px;
            border: none;
            white-space: nowrap;
        }

        .table tbody td {
            padding: 14px 16px;
            vertical-align: middle;
            border-color: #eef2f7;
            color: #111827;
        }

        .table tbody tr:hover {
            background: #f9fafb;
        }

    .action-group {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .edit-row {
        background: var(--edit-bg) !important;
    }

    .alert {
        border-radius: 14px;
        box-shadow: var(--shadow);
    }

    .alert-success {
        background: var(--success);
        border: 1px solid #bbf7d0;
        color: #166534;
    }

    .alert-danger {
        background: var(--danger);
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    .empty-row {
        text-align: center;
        color: var(--text-soft);
        padding: 24px !important;
    }
</style>

<div class="page-shell">
    <div class="page-header">
        <h2>Payment Management</h2>
        <p>
            Payment amount must match the ticket price. If payment status is marked as Paid,
            the related ticket is automatically updated to Booked.
        </p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="panel">
        <div class="panel-body">
            <h4 class="panel-title">Add New Payment</h4>

            <form method="post" asp-action="Create" class="row g-3">
                @Html.AntiForgeryToken()

                <div class="col-md-2">
                    <label class="form-label">Payment ID</label>
                    <input type="text" name="paymentId" class="form-control" required />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Ticket</label>
                    <select class="form-select" name="ticketId" required>
                        <option value="">Select Ticket</option>
                        @foreach (System.Data.DataRow t in tickets.Rows)
                        {
                            <option value="@t["TICKET_ID"]">@t["TICKET_ID"] - @t["MOVIE_TITLE"] - @t["CUSTOMER_NAME"] - Seat @t["SEAT_NUMBER"] - Rs. @t["BASE_TICKET_PRICE"]</option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Payment Mode</label>
                    <select class="form-select" name="paymentMode" required>
                        <option value="">Select Mode</option>
                        <option value="Cash">Cash</option>
                        <option value="Card">Card</option>
                        <option value="Online">Online</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Payment Date</label>
                    <input type="date" name="paymentDate" class="form-control" required />
                </div>

                <div class="col-md-1">
                    <label class="form-label">Amount</label>
                    <input type="number" step="0.01" name="amountPaid" class="form-control" required />
                </div>

                <div class="col-md-1">
                    <label class="form-label">Status</label>
                    <select class="form-select" name="paymentStatus" required>
                        <option value="">Select</option>
                        <option value="Paid">Paid</option>
                        <option value="Pending">Pending</option>
                        <option value="Failed">Failed</option>
                    </select>
                </div>

                <div class="col-12">
                    <button type="submit" class="btn btn-add">Add Payment</button>
                </div>
            </form>
        </div>
    </div>

    <div class="utility-bar">
        <h4>Payment Records</h4>
        <input type="text" id="paymentSearch" class="form-control search-box" placeholder="Search payment..." />
    </div>

    <div class="table-panel">
        <table class="table align-middle" id="paymentTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Ticket</th>
                    <th>Mode</th>
                    <th>Date</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th style="width:220px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Rows.Count > 0)
                {
                    @foreach (System.Data.DataRow row in Model.Rows)
                    {
                        var id = row["PAYMENT_ID"].ToString();
                        var ticketId = row["TICKET_ID"].ToString();
                        var paymentMode = row["PAYMENT_MODE"].ToString();
                        var amountPaid = row["AMOUNT_PAID"].ToString();
                        var paymentStatus = row["PAYMENT_STATUS"].ToString();

                        DateTime paymentDate = Convert.ToDateTime(row["PAYMENT_DATE"]);
                        string inputDate = paymentDate.ToString("yyyy-MM-dd");
                        string displayDate = paymentDate.ToString("dd/MM/yyyy");

                        <tr id="viewRow_@id">
                            <td>@id</td>
                            <td>@ticketId</td>
                            <td>@paymentMode</td>
                            <td>@displayDate</td>
                            <td>@amountPaid</td>
                            <td>@paymentStatus</td>
                            <td>
                                <div class="action-group">
                                    <button type="button" class="btn btn-edit btn-sm" onclick="enableEdit('@id')">Edit</button>

                                    <form method="post" asp-action="Delete" style="display:inline;" onsubmit="return confirm('Delete this payment?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="paymentId" value="@id" />
                                        <button type="submit" class="btn btn-delete btn-sm">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>

                        <tr id="editRow_@id" class="edit-row" style="display:none;">
                            <td colspan="7">
                                <form method="post" asp-action="Update" class="row g-3 align-items-end">
                                    @Html.AntiForgeryToken()

                                    <div class="col-md-2">
                                        <label class="form-label">Payment ID</label>
                                        <input type="text" name="paymentId" value="@id" class="form-control" readonly />
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label">Ticket</label>
                                        <select class="form-select" name="ticketId" required>
                                            @foreach (System.Data.DataRow t in tickets.Rows)
                                            {
                                                if (t["TICKET_ID"].ToString() == ticketId)
                                                {
                                                    <option value="@t["TICKET_ID"]" selected>@t["TICKET_ID"] - @t["MOVIE_TITLE"] - @t["CUSTOMER_NAME"] - Seat @t["SEAT_NUMBER"] - Rs. @t["BASE_TICKET_PRICE"]</option>
                                                }
                                                else
                                                {
                                                    <option value="@t["TICKET_ID"]">@t["TICKET_ID"] - @t["MOVIE_TITLE"] - @t["CUSTOMER_NAME"] - Seat @t["SEAT_NUMBER"] - Rs. @t["BASE_TICKET_PRICE"]</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                    <div class="col-md-2">
                                        <label class="form-label">Mode</label>
                                        <select class="form-select" name="paymentMode" required>
                                            @if (paymentMode == "Cash")
                                            {
                                                <option value="Cash" selected>Cash</option>
                                            }
                                            else
                                            {
                                                <option value="Cash">Cash</option>
                                            }

                                            @if (paymentMode == "Card")
                                            {
                                                <option value="Card" selected>Card</option>
                                            }
                                            else
                                            {
                                                <option value="Card">Card</option>
                                            }

                                            @if (paymentMode == "Online")
                                            {
                                                <option value="Online" selected>Online</option>
                                            }
                                            else
                                            {
                                                <option value="Online">Online</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="col-md-2">
                                        <label class="form-label">Payment Date</label>
                                        <input type="date" name="paymentDate" value="@inputDate" class="form-control" required />
                                    </div>

                                    <div class="col-md-1">
                                        <label class="form-label">Amount</label>
                                        <input type="number" step="0.01" name="amountPaid" value="@amountPaid" class="form-control" required />
                                    </div>

                                    <div class="col-md-1">
                                        <label class="form-label">Status</label>
                                        <select class="form-select" name="paymentStatus" required>
                                            @if (paymentStatus == "Paid")
                                            {
                                                <option value="Paid" selected>Paid</option>
                                            }
                                            else
                                            {
                                                <option value="Paid">Paid</option>
                                            }

                                            @if (paymentStatus == "Pending")
                                            {
                                                <option value="Pending" selected>Pending</option>
                                            }
                                            else
                                            {
                                                <option value="Pending">Pending</option>
                                            }

                                            @if (paymentStatus == "Failed")
                                            {
                                                <option value="Failed" selected>Failed</option>
                                            }
                                            else
                                            {
                                                <option value="Failed">Failed</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="col-12">
                                        <div class="action-group mt-2">
                                            <button type="submit" class="btn btn-save btn-sm">Save</button>
                                            <button type="button" class="btn btn-cancel btn-sm" onclick="cancelEdit('@id')">Cancel</button>
                                        </div>
                                    </div>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="empty-row">No payment records found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function enableEdit(id) {
        document.getElementById("viewRow_" + id).style.display = "none";
        document.getElementById("editRow_" + id).style.display = "";
    }

    function cancelEdit(id) {
        document.getElementById("editRow_" + id).style.display = "none";
        document.getElementById("viewRow_" + id).style.display = "";
    }

    document.getElementById("paymentSearch").addEventListener("keyup", function () {
        let filter = this.value.toLowerCase();
        let rows = document.querySelectorAll("#paymentTable tbody tr");

        rows.forEach(row => {
            let text = row.innerText.toLowerCase();
            row.style.display = text.includes(filter) ? "" : "none";
        });
    });
</script>