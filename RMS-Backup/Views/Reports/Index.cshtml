@{
    ViewData["Title"] = "Reports";
    var customers = ViewBag.Customers as System.Data.DataTable;
    var halls = ViewBag.Halls as System.Data.DataTable;
    var movies = ViewBag.Movies as System.Data.DataTable;

    var r1 = ViewBag.Report1 as System.Data.DataTable;
    var r2 = ViewBag.Report2 as System.Data.DataTable;
    var r3 = ViewBag.Report3 as System.Data.DataTable;
    var r4 = ViewBag.Report4 as System.Data.DataTable;
    var r5 = ViewBag.Report5 as System.Data.DataTable;
    string reportTitle = ViewBag.ReportTitle as string ?? "";
}

<style>
    :root {
        --bg: #f6f8fb;
        --surface: #ffffff;
        --border: #e5e7eb;
        --border-dark: #d1d5db;
        --text: #111827;
        --text-soft: #6b7280;
        --secondary: #475569;
        --primary: #1f2937;
        --hover: #f9fafb;
        --shadow: 0 10px 30px rgba(15,23,42,0.06);
        --radius: 18px;
    }

    body {
        background: var(--bg);
    }

    .page-shell {
        padding: 8px 0 20px;
    }

    .page-header {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 28px 30px;
        margin-bottom: 26px;
        box-shadow: var(--shadow);
    }

        .page-header h2 {
            margin: 0;
            font-size: 29px;
            font-weight: 700;
            color: var(--text);
        }

        .page-header p {
            margin: 8px 0 0;
            color: var(--text-soft);
            line-height: 1.7;
            font-size: 15px;
        }

    .reports-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 18px;
        margin-bottom: 26px;
    }

    .report-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 22px;
    }

        .report-card h5 {
            margin-bottom: 14px;
            color: var(--text);
            font-size: 18px;
            font-weight: 700;
        }

        .report-card p {
            font-size: 14px;
            color: var(--text-soft);
            margin-bottom: 14px;
        }

    .form-label {
        font-weight: 600;
        color: var(--secondary);
        margin-bottom: 7px;
        font-size: 14px;
    }

    .form-control, .form-select {
        border-radius: 12px;
        border: 1px solid var(--border-dark);
        min-height: 44px;
        padding: 10px 14px;
    }

        .form-control:focus, .form-select:focus {
            border-color: #94a3b8;
            box-shadow: 0 0 0 .2rem rgba(148,163,184,.15);
        }

    .btn-generate {
        background: var(--primary);
        color: #fff;
        border-radius: 12px;
        font-weight: 600;
        padding: 10px 16px;
        border: none;
        margin-top: 12px;
    }

        .btn-generate:hover {
            background: #111827;
            color: #fff;
        }

    .result-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 22px;
        margin-top: 10px;
    }

        .result-card h4 {
            margin-bottom: 16px;
            color: var(--text);
            font-weight: 700;
        }

    .table-wrap {
        overflow-x: auto;
    }

    .table {
        margin-bottom: 0;
        min-width: 900px;
    }

        .table thead th {
            background: #1f2937;
            color: white;
            font-weight: 700;
            font-size: 14px;
            padding: 14px 16px;
            border: none;
            white-space: nowrap;
        }

        .table tbody td {
            padding: 14px 16px;
            vertical-align: middle;
            border-color: #eef2f7;
            color: var(--text);
        }

        .table tbody tr:hover {
            background: var(--hover);
        }

    .summary-card {
        background: #f8fafc;
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 18px;
        margin-top: 10px;
        color: var(--text-soft);
    }

    @@media (max-width: 992px) {
        .reports-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="page-shell">
    <div class="page-header">
        <h2>Reports Dashboard</h2>
        <p>
            Generate meaningful reports for customers, halls, movies, occupancy, revenue, and ticket status.
            These reports help analyze booking activity and cinema performance in a clear way.
        </p>
    </div>

    <div class="reports-grid">
        <div class="report-card">
            <h5>Customer Tickets (Last 6 Months)</h5>
            <p>Shows recent ticket history of a selected customer.</p>
            <form method="post" asp-action="CustomerTickets">
                @Html.AntiForgeryToken()
                <label class="form-label">Customer</label>
                <select class="form-select" name="customerId" required>
                    <option value="">Select Customer</option>
                    @foreach (System.Data.DataRow c in customers.Rows)
                    {
                        <option value="@c["CUSTOMER_ID"]">@c["CUSTOMER_ID"] - @c["CUSTOMER_NAME"]</option>
                    }
                </select>
                <button class="btn btn-generate" type="submit">Generate Report</button>
            </form>
        </div>

        <div class="report-card">
            <h5>Hall Show Schedule</h5>
            <p>Displays all shows planned inside a selected hall.</p>
            <form method="post" asp-action="HallShows">
                @Html.AntiForgeryToken()
                <label class="form-label">Hall</label>
                <select class="form-select" name="hallId" required>
                    <option value="">Select Hall</option>
                    @foreach (System.Data.DataRow h in halls.Rows)
                    {
                        <option value="@h["HALL_ID"]">@h["HALL_ID"] - @h["HALL_NAME"] (@h["THEATRE_NAME"])</option>
                    }
                </select>
                <button class="btn btn-generate" type="submit">Generate Report</button>
            </form>
        </div>

        <div class="report-card">
            <h5>Top 3 Occupancy by Movie</h5>
            <p>Finds top 3 halls with the highest paid occupancy for a selected movie.</p>
            <form method="post" asp-action="Top3Occupancy">
                @Html.AntiForgeryToken()
                <label class="form-label">Movie</label>
                <select class="form-select" name="movieId" required>
                    <option value="">Select Movie</option>
                    @foreach (System.Data.DataRow m in movies.Rows)
                    {
                        <option value="@m["MOVIE_ID"]">@m["MOVIE_ID"] - @m["MOVIE_TITLE"]</option>
                    }
                </select>
                <button class="btn btn-generate" type="submit">Generate Report</button>
            </form>
        </div>

        <div class="report-card">
            <h5>Revenue by Movie</h5>
            <p>Calculates total revenue, shows, and tickets for a selected movie.</p>
            <form method="post" asp-action="RevenueByMovie">
                @Html.AntiForgeryToken()
                <label class="form-label">Movie</label>
                <select class="form-select" name="movieId" required>
                    <option value="">Select Movie</option>
                    @foreach (System.Data.DataRow m in movies.Rows)
                    {
                        <option value="@m["MOVIE_ID"]">@m["MOVIE_ID"] - @m["MOVIE_TITLE"]</option>
                    }
                </select>
                <button class="btn btn-generate" type="submit">Generate Report</button>
            </form>
        </div>

        <div class="report-card">
            <h5>Ticket Status Summary</h5>
            <p>Shows summary count of pending, booked, and cancelled tickets.</p>
            <form method="post" asp-action="TicketStatusSummary">
                @Html.AntiForgeryToken()
                <button class="btn btn-generate" type="submit">Generate Report</button>
            </form>
        </div>
    </div>

    @if (r1 != null || r2 != null || r3 != null || r4 != null || r5 != null)
    {
        <div class="result-card">
            <h4>@reportTitle</h4>

            @if (r1 != null)
            {
                <div class="table-wrap">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                @foreach (System.Data.DataColumn col in r1.Columns)
                                {
                                    <th>@col.ColumnName.Replace("_", " ")</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (System.Data.DataRow row in r1.Rows)
                            {
                                <tr>
                                    @foreach (var item in row.ItemArray)
                                    {
                                        <td>@item</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if (r2 != null)
            {
                <div class="table-wrap">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                @foreach (System.Data.DataColumn col in r2.Columns)
                                {
                                    <th>@col.ColumnName.Replace("_", " ")</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (System.Data.DataRow row in r2.Rows)
                            {
                                <tr>
                                    @foreach (var item in row.ItemArray)
                                    {
                                        <td>@item</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if (r3 != null)
            {
                <div class="table-wrap">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                @foreach (System.Data.DataColumn col in r3.Columns)
                                {
                                    <th>@col.ColumnName.Replace("_", " ")</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (System.Data.DataRow row in r3.Rows)
                            {
                                <tr>
                                    @foreach (var item in row.ItemArray)
                                    {
                                        <td>@item</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if (r4 != null)
            {
                <div class="table-wrap">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                @foreach (System.Data.DataColumn col in r4.Columns)
                                {
                                    <th>@col.ColumnName.Replace("_", " ")</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (System.Data.DataRow row in r4.Rows)
                            {
                                <tr>
                                    @foreach (var item in row.ItemArray)
                                    {
                                        <td>@item</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if (r5 != null)
            {
                <div class="table-wrap">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                @foreach (System.Data.DataColumn col in r5.Columns)
                                {
                                    <th>@col.ColumnName.Replace("_", " ")</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (System.Data.DataRow row in r5.Rows)
                            {
                                <tr>
                                    @foreach (var item in row.ItemArray)
                                    {
                                        <td>@item</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if ((r1 != null && r1.Rows.Count == 0) ||
                    (r2 != null && r2.Rows.Count == 0) ||
                    (r3 != null && r3.Rows.Count == 0) ||
                    (r4 != null && r4.Rows.Count == 0) ||
                    (r5 != null && r5.Rows.Count == 0))
            {
                <div class="summary-card">
                    No records found for the selected report.
                </div>
            }
        </div>
    }
</div>