@model System.Data.DataTable
@using System
@{
    ViewData["Title"] = "Show Management";
    var movies = ViewBag.Movies as System.Data.DataTable;
    var halls = ViewBag.Halls as System.Data.DataTable;
}

<style>
    :root {
        --bg: #f6f8fb;
        --surface: #fff;
        --border: #e5e7eb;
        --border-dark: #d1d5db;
        --text: #111827;
        --text-soft: #6b7280;
        --secondary: #475569;
        --hover: #f9fafb;
        --edit-bg: #f8fafc;
        --success: #f0fdf4;
        --danger: #fef2f2;
        --shadow: 0 10px 30px rgba(15,23,42,0.06);
        --radius: 18px;
    }

    body {
        background: var(--bg);
    }

    .page-shell {
        padding: 8px 0 20px;
    }

    .page-header, .panel, .table-panel {
        background: var(--surface);
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
    }

    .page-header {
        border-radius: 24px;
        padding: 28px 30px;
        margin-bottom: 26px;
    }

        .page-header h2 {
            margin: 0;
            font-size: 29px;
            font-weight: 700;
            color: var(--text);
        }

        .page-header p {
            margin: 8px 0 0;
            color: var(--text-soft);
            line-height: 1.7;
            font-size: 15px;
        }

    .panel {
        border-radius: var(--radius);
        margin-bottom: 24px;
    }

    .panel-body {
        padding: 24px;
    }

    .panel-title {
        margin: 0 0 18px;
        color: var(--text);
        font-size: 20px;
        font-weight: 650;
    }

    .form-label {
        font-weight: 600;
        color: var(--secondary);
        margin-bottom: 7px;
        font-size: 14px;
    }

    .form-control, .form-select {
        border-radius: 12px;
        border: 1px solid var(--border-dark);
        min-height: 44px;
        padding: 10px 14px;
    }

        .form-control:focus, .form-select:focus {
            border-color: #94a3b8;
            box-shadow: 0 0 0 .2rem rgba(148,163,184,.15);
        }

    .btn {
        border-radius: 12px;
        font-weight: 600;
        padding: 10px 16px;
    }

    .btn-add, .btn-save {
        background: #1f2937;
        color: #fff;
    }

        .btn-add:hover, .btn-save:hover {
            background: #111827;
            color: #fff;
        }

    .btn-edit, .btn-cancel {
        background: #fff;
        color: #334155;
        border: 1px solid #cbd5e1;
    }

        .btn-edit:hover, .btn-cancel:hover {
            background: #f8fafc;
            color: #111827;
        }

    .btn-delete {
        background: #fff;
        color: #7f1d1d;
        border: 1px solid #fecaca;
    }

        .btn-delete:hover {
            background: #fef2f2;
            color: #7f1d1d;
        }

    .utility-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        margin-bottom: 14px;
    }

        .utility-bar h4 {
            margin: 0;
            font-size: 20px;
            font-weight: 650;
            color: var(--text);
        }

    .search-box {
        max-width: 320px;
    }

    .table-panel {
        border-radius: var(--radius);
        overflow-x: auto;
    }

    .table {
        margin-bottom: 0;
        min-width: 980px;
    }

        .table thead th {
            background: #1f2937;
            color: #ffffff;
            font-weight: 700;
            font-size: 14px;
            padding: 14px 16px;
            border: none;
            text-transform: none;
            letter-spacing: 0;
            vertical-align: middle;
            white-space: nowrap;
        }

        .table tbody td {
            padding: 14px 16px;
            vertical-align: middle;
            border-color: #eef2f7;
            color: #111827;
        }

        .table tbody tr:hover {
            background: #f9fafb;
        }

    .action-group {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .edit-row {
        background: var(--edit-bg) !important;
    }

    .alert {
        border-radius: 14px;
        box-shadow: var(--shadow);
    }

    .alert-success {
        background: var(--success);
        border: 1px solid #bbf7d0;
        color: #166534;
    }

    .alert-danger {
        background: var(--danger);
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    .empty-row {
        text-align: center;
        color: var(--text-soft);
        padding: 24px !important;
    }

    .col-show-id {
        width: 110px;
    }

    .col-movie {
        width: 220px;
    }

    .col-hall {
        width: 220px;
    }

    .col-date {
        width: 140px;
    }

    .col-time {
        width: 120px;
        white-space: nowrap;
    }

    .col-price {
        width: 120px;
        white-space: nowrap;
    }

    .col-actions {
        width: 180px;
    }

    .time-input {
        min-width: 120px;
    }

    .price-input {
        min-width: 110px;
    }

    .date-input {
        min-width: 140px;
    }
</style>

<div class="page-shell">
    <div class="page-header">
        <h2>Show Management</h2>
        <p>
            Add, search, edit, and delete show schedules from one page.
            A show cannot be duplicated in the same hall at the same date and time.
        </p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="panel">
        <div class="panel-body">
            <h4 class="panel-title">Add New Show</h4>

            <form method="post" asp-action="Create" class="row g-3">
                @Html.AntiForgeryToken()

                <div class="col-md-2">
                    <label class="form-label">Show ID</label>
                    <input type="text" name="showId" class="form-control" required />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Movie</label>
                    <select class="form-select" name="movieId" required>
                        <option value="">Select Movie</option>
                        @foreach (System.Data.DataRow m in movies.Rows)
                        {
                            <option value="@m["MOVIE_ID"]">@m["MOVIE_ID"] - @m["MOVIE_TITLE"]</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Hall</label>
                    <select class="form-select" name="hallId" required>
                        <option value="">Select Hall</option>
                        @foreach (System.Data.DataRow h in halls.Rows)
                        {
                            <option value="@h["HALL_ID"]">@h["HALL_ID"] - @h["HALL_NAME"] (@h["THEATRE_NAME"])</option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Date</label>
                    <input type="date" name="showDate" class="form-control date-input" required />
                </div>

                <div class="col-md-1">
                    <label class="form-label">Time</label>
                    <input type="time" name="showTime" class="form-control time-input" required />
                </div>

                <div class="col-md-1">
                    <label class="form-label">Price</label>
                    <input type="number" step="0.01" name="baseTicketPrice" class="form-control price-input" required />
                </div>

                <div class="col-12">
                    <button type="submit" class="btn btn-add">Add Show</button>
                </div>
            </form>
        </div>
    </div>

    <div class="utility-bar">
        <h4>Show Records</h4>
        <input type="text" id="showSearch" class="form-control search-box" placeholder="Search show..." />
    </div>

    <div class="table-panel">
        <table class="table align-middle" id="showTable">
            <thead>
                <tr>
                    <th class="col-show-id">ID</th>
                    <th class="col-movie">Movie</th>
                    <th class="col-hall">Hall</th>
                    <th class="col-date">Date</th>
                    <th class="col-time">Time</th>
                    <th class="col-price">Price</th>
                    <th class="col-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Rows.Count > 0)
                {
                    @foreach (System.Data.DataRow row in Model.Rows)
                    {
                        var id = row["SHOW_ID"].ToString();
                        var movieId = row["MOVIE_ID"].ToString();
                        var movieTitle = row["MOVIE_TITLE"].ToString();
                        var hallId = row["HALL_ID"].ToString();
                        var hallName = row["HALL_NAME"].ToString();
                        var theatreName = row["THEATRE_NAME"].ToString();
                        var showTime = row["SHOW_TIME"].ToString();
                        var price = row["BASE_TICKET_PRICE"].ToString();

                        DateTime showDate = Convert.ToDateTime(row["SHOW_DATE"]);
                        string displayDate = showDate.ToString("dd/MM/yyyy");
                        string inputDate = showDate.ToString("yyyy-MM-dd");

                        <tr id="viewRow_@id">
                            <td>@id</td>
                            <td>@movieTitle</td>
                            <td>@hallName (@theatreName)</td>
                            <td>@displayDate</td>
                            <td class="col-time">@showTime</td>
                            <td class="col-price">@price</td>
                            <td>
                                <div class="action-group">
                                    <button type="button" class="btn btn-edit btn-sm" onclick="enableEdit('@id')">Edit</button>

                                    <form method="post" asp-action="Delete" style="display:inline;" onsubmit="return confirm('Delete this show?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="showId" value="@id" />
                                        <button type="submit" class="btn btn-delete btn-sm">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>

                        <tr id="editRow_@id" class="edit-row" style="display:none;">
                            <td colspan="7">
                                <form method="post" asp-action="Update" class="row g-3 align-items-end">
                                    @Html.AntiForgeryToken()

                                    <div class="col-md-2">
                                        <label class="form-label">Show ID</label>
                                        <input type="text" name="showId" value="@id" class="form-control" readonly />
                                    </div>

                                    <div class="col-md-3">
                                        <label class="form-label">Movie</label>
                                        <select class="form-select" name="movieId" required>
                                            @foreach (System.Data.DataRow m in movies.Rows)
                                            {
                                                if (m["MOVIE_ID"].ToString() == movieId)
                                                {
                                                    <option value="@m["MOVIE_ID"]" selected>@m["MOVIE_ID"] - @m["MOVIE_TITLE"]</option>
                                                }
                                                else
                                                {
                                                    <option value="@m["MOVIE_ID"]">@m["MOVIE_ID"] - @m["MOVIE_TITLE"]</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                    <div class="col-md-3">
                                        <label class="form-label">Hall</label>
                                        <select class="form-select" name="hallId" required>
                                            @foreach (System.Data.DataRow h in halls.Rows)
                                            {
                                                if (h["HALL_ID"].ToString() == hallId)
                                                {
                                                    <option value="@h["HALL_ID"]" selected>@h["HALL_ID"] - @h["HALL_NAME"] (@h["THEATRE_NAME"])</option>
                                                }
                                                else
                                                {
                                                    <option value="@h["HALL_ID"]">@h["HALL_ID"] - @h["HALL_NAME"] (@h["THEATRE_NAME"])</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                    <div class="col-md-2">
                                        <label class="form-label">Date</label>
                                        <input type="date" name="showDate" value="@inputDate" class="form-control date-input" required />
                                    </div>

                                    <div class="col-md-1">
                                        <label class="form-label">Time</label>
                                        <input type="time" name="showTime" value="@showTime" class="form-control time-input" required />
                                    </div>

                                    <div class="col-md-1">
                                        <label class="form-label">Price</label>
                                        <input type="number" step="0.01" name="baseTicketPrice" value="@price" class="form-control price-input" required />
                                    </div>

                                    <div class="col-12">
                                        <div class="action-group mt-2">
                                            <button type="submit" class="btn btn-save btn-sm">Save</button>
                                            <button type="button" class="btn btn-cancel btn-sm" onclick="cancelEdit('@id')">Cancel</button>
                                        </div>
                                    </div>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="empty-row">No show records found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function enableEdit(id) {
        document.getElementById("viewRow_" + id).style.display = "none";
        document.getElementById("editRow_" + id).style.display = "";
    }

    function cancelEdit(id) {
        document.getElementById("editRow_" + id).style.display = "none";
        document.getElementById("viewRow_" + id).style.display = "";
    }

    document.getElementById("showSearch").addEventListener("keyup", function () {
        let filter = this.value.toLowerCase();
        let rows = document.querySelectorAll("#showTable tbody tr");

        rows.forEach(row => {
            let text = row.innerText.toLowerCase();
            row.style.display = text.includes(filter) ? "" : "none";
        });
    });
</script>